{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-livy/refs/heads/main/json-schema/rest-api-log-schema.json",
  "title": "Log",
  "description": "Log output",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "example": 0
    },
    "from": {
      "type": "integer",
      "example": 0
    },
    "size": {
      "type": "integer",
      "example": 100
    },
    "log": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}